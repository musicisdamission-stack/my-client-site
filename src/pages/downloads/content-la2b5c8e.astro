      <div class="space-y-4 text-neutral-300 text-sm leading-relaxed">
        {post.body.split('\n\n').map((para) => (
          <p>{para}</p>
        ))}
      </div>
    </article>
  ))}

  <hr class="border-neutral-800 mb-10" />
  <p class="text-xs text-neutral-600">NetiVana · Content Generation Pack · Thank you for your purchase.</p>
</div>
